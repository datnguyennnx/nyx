{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "write": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "*git*": "deny",
      "git add*": "deny",
      "git commit*": "deny",
      "git diff*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",

      "cat .env*": "deny",
      "cat */.env*": "deny",
      "grep * .env*": "deny",
      "sed * .env*": "deny",
      "awk * .env*": "deny",
      "less .env*": "deny",
      "head .env*": "deny",
      "tail .env*": "deny",
      "printenv*": "deny",
      "env*": "deny"
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false
    }
  },
  "mode": {
    "ship-effect-ts": {
      "prompt": "{file:./modes/ship-effect-ts.md}",
      "tools": {
        "read": false,
        "task": true,
        "write": false,
        "edit": false,
        "bash": false,
        "grep": false,
        "glob": false,
        "list": false,
        "patch": false
      }
    },
    "ship-react-vite": {
      "prompt": "{file:./modes/ship-react-vite.md}",
      "tools": {
        "read": false,
        "task": true,
        "write": false,
        "edit": false,
        "bash": false,
        "grep": false,
        "glob": false,
        "list": false,
        "patch": false
      }
    },
    "ship-fullstack": {
      "prompt": "{file:./modes/ship-fullstack.md}",
      "tools": {
        "read": false,
        "task": true,
        "write": false,
        "edit": false,
        "bash": false,
        "grep": false,
        "glob": false,
        "list": false,
        "patch": false
      }
    }
  }
}
