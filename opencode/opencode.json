{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "The MAS architecture uses a Deterministic Automata (TS Engine) for control flow. LLM agents are pure execution templates that receive domain skills via engine injection."
  ],
  "permission": {
    "read": {
      "*": "allow",
      "~/.config/opencode/**/*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "find": {
      "*": "allow"
    },
    "rg": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git*": "deny",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "cat .env*": "deny",
      "cat */.env*": "deny",
      "printenv*": "deny",
      "env": "deny",
      "node*": "ask",
      "python*": "ask",
      "python3*": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**/*": "allow"
    }
  },
  "mode": {
    "ship-mas": {
      "prompt": "{file:./modes/ship-mas.md}",
      "permission": {
        "task": "allow",
        "skill": "allow",
        "read": "allow",
        "edit": "deny",
        "bash": "deny",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "run_manifest": "allow",
        "question": "allow"
      }
    }
  }
}