{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "MAS uses a light orchestrator (ship-mas) that decomposes tasks using information-theoretic complexity scoring, spawns generic agents in parallel via task tool, and verifies with mechanical tsc/eslint gates. No JSON manifests. No engine plugin. Agents are self-contained with direct tool access."
  ],
  "permission": {
    "read": {
      "*": "allow",
      "~/.config/opencode/**/*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "find": {
      "*": "allow"
    },
    "rg": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git*": "deny",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "cat .env*": "deny",
      "cat */.env*": "deny",
      "printenv*": "deny",
      "env": "deny",
      "node*": "ask",
      "python*": "ask",
      "python3*": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**/*": "allow"
    }
  },
  "mode": {
    "ship-mas": {
      "prompt": "{file:./modes/ship-mas.md}",
      "permission": {
        "task": "allow",
        "skill": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "todowrite": "allow",
        "question": "allow",
        "read": "deny",
        "edit": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    }
  },
  "agent": {
    "discovery": {
      "permission": {
        "task": "deny"
      }
    },
    "architect": {
      "permission": {
        "task": "deny"
      }
    },
    "implementer": {
      "permission": {
        "task": "deny"
      }
    },
    "fixer": {
      "permission": {
        "task": "deny"
      }
    },
    "verifier": {
      "permission": {
        "task": "deny"
      }
    }
  }
}