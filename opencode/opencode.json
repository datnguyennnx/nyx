{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
     "MAS uses an orchestrator (ship-mas) that decomposes tasks using information-theoretic complexity scoring, spawns agents in parallel via task tool, and verifies output before completing. 4 sub-agents: discovery, diagnostician, implementer, researcher. Agents are self-contained with direct tool access. General/explore agent spawning is blocked in mode to prevent recursion.",
    "CRITICAL: Respect repository rules. Every repo defines agent rules via AGENTS.md and markdown files in its root. Read them as priority instructions. Never skip or override the instruction author."
  ],
  "permission": {
    "read": {
      "*": "allow",
      "~/.config/opencode/**/*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "ask",
      "*.env.example": "ask"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "git*": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "cat .env*": "deny",
      "cat */.env*": "deny",
      "printenv*": "deny",
      "env": "deny",
      "node*": "ask",
      "python*": "ask",
      "python3*": "ask",
      "rm": "deny"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**/*": "allow"
    }
  },
  "mode": {
    "ship-mas": {
      "prompt": "{file:./modes/ship-mas.md}",
      "permission": {
        "task": {
          "general": "deny",
          "explore": "deny",
          "*": "allow"
        },
        "skill": "allow",
        "bash": {
          "*": "deny",
          "ls": "allow",
          "ls *": "allow",
          "find": "allow",
          "find *": "allow",
          "grep": "allow",
          "grep *": "allow",
          "rg": "allow",
          "rg *": "allow",
          "head": "allow",
          "head *": "allow",
          "which": "allow",
          "which *": "allow",
          "node": "allow",
          "node *": "allow",
          "tsc": "allow",
          "tsc *": "allow",
          "eslint": "allow",
          "eslint *": "allow",
          "cargo": "allow",
          "cargo *": "allow",
          "rustc": "allow",
          "rustc *": "allow",
          "git diff *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git branch *": "allow",
          "git add*": "ask",
          "git checkout*": "ask",
          "git commit*": "ask",
          "git merge*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git restore*": "ask",
          "mkdir": "allow",
          "mkdir *": "ask",
          "mv": "allow",
          "mv *": "ask",
          "cp": "allow",
          "cp *": "ask",
          "python": "ask",
          "python *": "ask",
          "python3": "ask",
          "python3 *": "ask",
          "cat .env*": "deny",
          "cat */.env*": "deny",
          "cat *<<*": "deny",
          "cat *>*": "deny"
        },
        "todowrite": "allow",
        "question": "allow",
        "read": "deny",
        "edit": "deny",
        "glob": "deny"
      }
    }
  },
  "agent": {
    "discovery": {
      "permission": {
        "task": "deny"
      }
    },
    "diagnostician": {
      "permission": {
        "task": "deny"
      }
    },
    "implementer": {
      "permission": {
        "task": "deny",
        "bash": { "*": "allow" }
      }
    },
    "researcher": {
      "permission": {
        "task": "deny"
      }
    }
  }
}
