{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "Read ./AGENTS.md for repository architecture and MAS rules.",
    "Read ./agents/context-manager.md to enforce context tiers before routing agents."
  ],
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git*": "deny",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "cat .env*": "deny",
      "cat */.env*": "deny",
      "printenv*": "deny",
      "env": "deny"
    },
    "external_directory": "ask",
    "skill": "allow"
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false
    }
  },
  "mode": {
    "ship-effect-ts": {
      "prompt": "{file:./modes/ship-effect-ts.md}",
      "permission": {
        "task": "allow",
        "skill": "allow",
        "read": "deny",
        "edit": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny",
        "webfetch": "deny"
      }
    },
    "ship-react-vite": {
      "prompt": "{file:./modes/ship-react-vite.md}",
      "permission": {
        "task": "allow",
        "skill": "allow",
        "read": "deny",
        "edit": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny",
        "webfetch": "deny"
      }
    },
    "ship-fullstack": {
      "prompt": "{file:./modes/ship-fullstack.md}",
      "permission": {
        "task": "allow",
        "skill": "allow",
        "read": "deny",
        "edit": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny",
        "webfetch": "deny"
      }
    }
  }
}
