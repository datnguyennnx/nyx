{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
    "*git*": "deny",
    "git add*": "deny",
    "git commit*": "deny",
    "git diff*": "allow",
    "git status*": "allow",
    "git log*": "allow",
    "git show*": "allow",
    "git branch*": "allow"
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false
    }
  },
  "mode": {
    "ship-effect-ts": {
      "prompt": "{file:./modes/ship-effect-ts.md}",
      "tools": {
        "read": false,
        "task": true,
        "write": false,
        "edit": false,
        "bash": false,
        "grep": false,
        "glob": false,
        "list": false,
        "patch": false
      }
    },
    "ship-react-vite": {
      "prompt": "{file:./modes/ship-react-vite.md}",
      "tools": {
        "read": false,
        "task": true,
        "write": false,
        "edit": false,
        "bash": false,
        "grep": false,
        "glob": false,
        "list": false,
        "patch": false
      }
    },
    "ship-fullstack": {
      "prompt": "{file:./modes/ship-fullstack.md}",
      "tools": {
        "read": false,
        "task": true,
        "write": false,
        "edit": false,
        "bash": false,
        "grep": false,
        "glob": false,
        "list": false,
        "patch": false
      }
    }
  }
}
