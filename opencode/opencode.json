{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "MAS uses an orchestrator (ship-mas) that decomposes tasks using information-theoretic complexity scoring, spawns generic agents in parallel via task tool, and verifies output before completing. 7 sub-agents: discovery, architecture, implementation, fix, verify, research, synthesis. Agents are self-contained with direct tool access.",
    "CRITICAL: Respect repository rules. Every repo defines agent rules via AGENTS.md and markdown files in its root. Read them as priority instructions. Never skip or override the instruction author."
  ],
  "permission": {
    "read": {
      "*": "allow",
      "~/.config/opencode/**/*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "find": {
      "*": "allow"
    },
    "rg": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git*": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "cat .env*": "deny",
      "cat */.env*": "deny",
      "printenv*": "deny",
      "env": "deny",
      "node*": "ask",
      "python*": "ask",
      "python3*": "ask",
      "rm": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**/*": "allow"
    }
  },
  "mode": {
    "ship-mas": {
      "prompt": "{file:./modes/ship-mas.md}",
      "permission": {
        "task": "allow",
        "skill": "allow",
        "bash": {
          "ls": "allow",
          "find": "allow",
          "node": "allow",
          "tsc": "allow",
          "eslint": "allow",
          "git*": "ask",
          "git diff *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git branch *": "allow",
          "mkdir": "allow",
          "mv": "allow",
          "cp": "allow",
          "*": "deny",
          "rm": "ask",
          "rm -rf *": "ask"
        },
        "todowrite": "allow",
        "question": "allow",
        "read": "deny",
        "edit": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    }
  },
  "agent": {
    "discovery": {
      "permission": {
        "task": "deny"
      }
    },
    "architect": {
      "permission": {
        "task": "deny"
      }
    },
    "implementer": {
      "permission": {
        "task": "deny"
      }
    },
    "fixer": {
      "permission": {
        "task": "deny"
      }
    },
    "verifier": {
      "permission": {
        "task": "deny"
      }
    },
    "researcher": {
      "permission": {
        "task": "deny"
      }
    },
    "synthesis": {
      "permission": {
        "task": "deny"
      }
    }
  }
}
