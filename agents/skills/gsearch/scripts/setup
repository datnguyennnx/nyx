#!/usr/bin/env bash
# setup — Standalone PATH and symlink setup for gsearch.
# Run this if gsearch is not on PATH after bootstrap.sh install.
# Usage: bash path/to/setup
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
skill_dir="$(dirname "$script_dir")"
target_dir="$HOME/.local/bin"
mkdir -p "$target_dir"

# Link gsearch
ln -sf "$skill_dir/scripts/gsearch" "$target_dir/gsearch"

# Link browser-harness-js
bhjs="$skill_dir/../cdp/sdk/browser-harness-js"
[ -f "$bhjs" ] && ln -sf "$bhjs" "$target_dir/browser-harness-js"

# Add to PATH if not present
if ! echo ":$PATH:" | grep -q ":$target_dir:"; then
  for f in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    if [ -f "$f" ] && ! grep -q '\.local/bin' "$f" 2>/dev/null; then
      printf '\nexport PATH="$HOME/.local/bin:$PATH"\n' >> "$f"
      echo "Added $target_dir to PATH in $f"
      break
    fi
  done
  export PATH="$target_dir:$PATH"
fi

echo "gsearch is ready. Restart your shell or run: export PATH=\"\$HOME/.local/bin:\$PATH\""
