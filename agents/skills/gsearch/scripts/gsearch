#!/usr/bin/env bash
# gsearch — web search + page automation for AI agents.
# Version: 2.0.0
# Usage: gsearch [command] [args...]
set -euo pipefail

VERSION="2.0.0"

# ════════════════════════════════════════════════════════════════════
# PRE-DISPATCH: --version and --help fast path
# ════════════════════════════════════════════════════════════════════
case "${1:-}" in
  --version|-v)
    printf 'gsearch v%s\n' "$VERSION"
    exit 0
    ;;
esac

# ════════════════════════════════════════════════════════════════════
# CONFIGURATION
# ════════════════════════════════════════════════════════════════════
GSEARCH_CDP_PORT="${GSEARCH_CDP_PORT:-9222}"
GSEARCH_TOKEN_DIR="${GSEARCH_TOKEN_DIR:-/tmp/gsearch-tokens}"

# ════════════════════════════════════════════════════════════════════
# SCRIPT LOCATION (follow symlinks, resolve relative paths)
# ════════════════════════════════════════════════════════════════════
SELF="$0"
if [ -L "$SELF" ]; then
  LINK="$(readlink "$SELF")"
  case "$LINK" in
    /*) SELF="$LINK" ;;
    *) SELF="$(cd "$(dirname "$SELF")" && pwd)/$LINK" ;;
  esac
fi
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
LIB="$SCRIPT_DIR/../lib"
CDP_SCRIPTS="$SCRIPT_DIR/../../cdp/scripts"
export CDP_SCRIPTS

# ════════════════════════════════════════════════════════════════════
# SOURCE LIBRARIES
# ════════════════════════════════════════════════════════════════════
. "$LIB/common.sh"
. "$LIB/actions.sh"

# ════════════════════════════════════════════════════════════════════
# PRE-FLIGHT VALIDATION
# ════════════════════════════════════════════════════════════════════
# Verify bun is available — required by all extraction commands
# (search, follow, screenshot, scrape, batch, pdftotext).
# Exit code 2 for operational/dependency errors.
if ! command -v bun >/dev/null 2>&1; then
  printf '{"tool":"gsearch","error":"dependency_missing","detail":"bun is required but not found in PATH"}\n' >&2
  exit 2
fi

# ════════════════════════════════════════════════════════════════════
# COMMAND DISPATCH
# ════════════════════════════════════════════════════════════════════
# Each cmd_* function parses its own flags (--max, --offset, --selector,
# --count, --pretty, etc.) from the remaining arguments.
# --max and --offset are forwarded transparently through "$@" to the
# cmd function, which passes them to browser-automation.ts.
case "${1:-}" in
  launch)     shift; cmd_launch "$@" ;;
  follow)     shift; cmd_follow "$@" ;;
  screenshot) shift; cmd_screenshot "$@" ;;
  scrape)     shift; cmd_scrape "$@" ;;
  batch)      shift; cmd_batch "$@" ;;
  pdftotext)  shift; cmd_pdftotext "$@" ;;
  help|--help|-h)
    printf 'Usage: gsearch <command> [args...]\n'
    printf '\nCommands:\n'
    printf '  launch              Start or reuse a browser instance with CDP\n'
    printf '  follow <url>        Extract text from a single URL\n'
    printf '  screenshot <url>    Capture a full-page PNG screenshot\n'
    printf '  scrape <url>        Extract structured data with CSS selectors\n'
    printf '  batch <subcommand>  Batch operations: search | follow | harvest\n'
    printf '  pdftotext <url>     Extract full text from a PDF (no character cap)\n'
    printf '  <query>             Search the web (default command)\n'
    printf '\nFlags:\n'
    printf '  --version, -v       Print version and exit\n'
    printf '  --help, -h          Show this help message\n'
    printf '\nBatch subcommands:\n'
    printf '  batch search --count N q1 q2 ...     Parallel search\n'
    printf '  batch follow --offset N --max M urls Parallel page read\n'
    printf '  batch harvest --count N --max M qs   Full research pipeline\n'
    exit 0
    ;;
  *)
    # Default: search mode — passes all remaining args to cmd_search
    # Supports --pretty and --count flags
    cmd_search "$@"
    ;;
esac
