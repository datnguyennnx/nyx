#!/usr/bin/env bash
# gsearch — web search + page automation for AI agents.
# Usage: gsearch [command] [args...]
set -euo pipefail

# --- config ---
GSEARCH_CDP_PORT="${GSEARCH_CDP_PORT:-9222}"
GSEARCH_TOKEN_DIR="${GSEARCH_TOKEN_DIR:-/tmp/gsearch-tokens}"

# --- source libs ---
SELF="$0"
if [ -L "$SELF" ]; then
  LINK="$(readlink "$SELF")"
  case "$LINK" in
    /*) SELF="$LINK" ;;
    *) SELF="$(cd "$(dirname "$SELF")" && pwd)/$LINK" ;;
  esac
fi
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
LIB="$SCRIPT_DIR/../lib"
CDP_SCRIPTS="$SCRIPT_DIR/../../cdp/scripts"
export CDP_SCRIPTS

. "$LIB/common.sh"
. "$LIB/actions.sh"

# --- dispatch ---
case "${1:-}" in
  launch)     shift; cmd_launch "$@" ;;
  follow)     shift; cmd_follow "$@" ;;
  screenshot) shift; cmd_screenshot "$@" ;;
  scrape)     shift; cmd_scrape "$@" ;;
  batch)      shift; cmd_batch "$@" ;;
  pdftotext)  shift; cmd_pdftotext "$@" ;;
  *)
    # default: search mode
    cmd_search "$@"
    ;;
esac
