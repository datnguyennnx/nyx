#!/usr/bin/env bash
# Security tests for gsearch — verify trust boundary enforcement.
# Exits 0 if all pass, 1 if any fail, 77 if browser/setup issue.
set -uo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
cli="$script_dir/gsearch"

if [ ! -f "$cli" ]; then echo "FAIL: $cli not found" >&2; exit 1; fi
if ! command -v browser-harness-js >/dev/null 2>&1; then echo "skip: browser-harness-js not on PATH" >&2; exit 77; fi

pass=0; fail=0
ok()  { echo "  PASS  $1"; pass=$((pass + 1)); }
bad() { echo "  FAIL  $1: $2" | head -3; fail=$((fail + 1)); }

# Helper: run gsearch, capture exit code
run() {
  local out status
  out=$("$cli" "$@" 2>&1) || status=$?
  printf '%s\n' "$out"
  return ${status:-0}
}

# ------ SETUP: launch trusted Chrome ------
echo "--- SETUP: gsearch launch ---"
launch_out=$(run launch 2>/dev/null)
if printf '%s' "$launch_out" | grep -q '"success":true'; then
  ok "launch: Chrome started with temp profile"
else
  bad "launch: Chrome start failed" "$launch_out"
fi

# ------ TEST 1: Trusted Chrome works ------
echo "--- TEST 1: Trusted Chrome ---"
search_out=$(run --count 1 "test" 2>/dev/null)
if printf '%s' "$search_out" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if isinstance(d,list) and len(d)>0 else 1)" 2>/dev/null; then
  ok "trusted: search returns results"
else
  bad "trusted: search no results" "$search_out"
fi

follow_out=$(run follow https://example.com 2>/dev/null)
if printf '%s' "$follow_out" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('success') else 1)" 2>/dev/null; then
  ok "trusted: follow returns success"
else
  bad "trusted: follow failed" "$follow_out"
fi

# ------ TEST 2: Token removal blocks access ------
echo "--- TEST 2: Token removal ---"
rm -f /tmp/gsearch-tokens/port-9222
blocked_out=$("$cli" --count 1 "test" 2>&1) || true
if printf '%s' "$blocked_out" | grep -q "not trusted"; then
  ok "block: no token → refused"
else
  bad "block: no token → allowed" "$blocked_out"
fi

# ------ TEST 3: Manual Chrome blocked ------
echo "--- TEST 3: Manual Chrome (no token) ---"
# Kill the trusted Chrome, launch unauthorized one
ps aux | grep -i "chrome.*remote-debugging" | grep -v grep | awk '{print $2}' | xargs kill -9 2>/dev/null || true
sleep 1
"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
  --remote-debugging-port=9222 \
  --user-data-dir="/tmp/gsearch-sec-test-unauth" \
  --no-first-run --new-window "about:blank" >/dev/null 2>&1 &
sleep 4

unauth_out=$("$cli" --count 1 "hack" 2>&1) || true
if printf '%s' "$unauth_out" | grep -q "not trusted"; then
  ok "block: manual Chrome → refused"
else
  bad "block: manual Chrome → allowed" "$unauth_out"
fi

# ------ TEST 4: GSEARCH_ALLOW_REAL bypass works (explicit opt-in) ------
echo "--- TEST 4: ALLOW_REAL bypass ---"
allow_out=$(GSEARCH_ALLOW_REAL=1 "$cli" --count 1 "test" 2>&1) || true
# Should succeed because it's an explicit opt-in
if printf '%s' "$allow_out" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if isinstance(d,list) else 1)" 2>/dev/null; then
  ok "allow: ALLOW_REAL=1 bypass works (with warning)"
else
  bad "allow: ALLOW_REAL=1 failed" "$allow_out"
fi

# ------ TEST 5: Kill unauthorized, re-launch trusted ------
echo "--- TEST 5: Re-launch trusted ==="
ps aux | grep -i "chrome.*remote-debugging" | grep -v grep | awk '{print $2}' | xargs kill -9 2>/dev/null || true
sleep 1; rm -f /tmp/gsearch-tokens/port-9222 2>/dev/null; rm -rf /tmp/gsearch-sec-test-unauth 2>/dev/null

relaunch=$(run launch 2>/dev/null)
if printf '%s' "$relaunch" | grep -q '"success":true'; then
  ok "relaunch: trusted Chrome started"
else
  bad "relaunch: failed" "$relaunch"
fi

relaunch_search=$(run --count 1 "effect-ts" 2>/dev/null)
if printf '%s' "$relaunch_search" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if isinstance(d,list) and len(d)>0 else 1)" 2>/dev/null; then
  ok "relaunch: search works"
else
  bad "relaunch: search failed" "$relaunch_search"
fi

# ------ SUMMARY ------
echo ""
echo "$pass passed, $fail failed"
[ "$fail" -eq 0 ]
