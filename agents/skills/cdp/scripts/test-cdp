#!/usr/bin/env bash
# test-gsearch — smoke test suite for gsearch commands.
# Tests every gsearch command pattern: launch, search, follow, batch, screenshot, pdftotext.
# Follows gsearch Playbook: launch first, then search/follow, then batch workflows.
# Each test is independent (one failure does not stop others).
set -euo pipefail

PASS=0
FAIL=0
TESTS=0
TIMEOUT=30

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLI="$SCRIPT_DIR/gsearch"

# ── Pre-flight checks ──────────────────────────────────────────────

[ -f "$CLI" ] || { echo "FAIL: $CLI not found" >&2; exit 1; }

command -v browser-harness-js >/dev/null 2>&1 || {
  echo "SKIP: browser-harness-js not on PATH (install cdp skill first)" >&2
  exit 77
}

# Detect timeout command (gtimeout on macOS, timeout on Linux)
TIMEOUT_CMD=""
for _c in timeout gtimeout; do
  if command -v "$_c" >/dev/null 2>&1; then
    TIMEOUT_CMD="$_c"
    break
  fi
done
[ -z "$TIMEOUT_CMD" ] && echo "WARNING: timeout(1) not found, tests may hang on failure" >&2

# ── Helpers ────────────────────────────────────────────────────────

# Run a gsearch command with 30s timeout, capturing stdout+stderr.
# Never exits non-zero (errors are handled by test assertions).
run() {
  if [ -n "$TIMEOUT_CMD" ]; then
    "$TIMEOUT_CMD" "$TIMEOUT" "$CLI" "$@" 2>&1 || true
  else
    "$CLI" "$@" 2>&1 || true
  fi
}

# Assert that $actual (string) contains the grep pattern $expected.
assert() {
  local name="$1" expected="$2" actual="$3"
  TESTS=$((TESTS+1))
  if printf '%s' "$actual" | grep -q "$expected"; then
    PASS=$((PASS+1))
    echo "  ✓ $name"
  else
    FAIL=$((FAIL+1))
    echo "  ✗ $name"
    echo "    Expected pattern: $expected"
    echo "    Got: $(printf '%s' "$actual" | head -5)"
  fi
}

# ── Tests ──────────────────────────────────────────────────────────

# Test 1: gsearch launch — confirm browser starts and returns metadata.
test_launch() {
  echo "--- 1. launch ---"
  local out
  out=$(run launch)
  assert "launch: success field"       '"success":true' "$out"
  assert "launch: port field"          '"port"'         "$out"
  assert "launch: pid field"           '"pid"'          "$out"
}

# Test 2: gsearch "query" — single-query Google search returns a JSON array.
test_search() {
  echo "--- 2. search ---"
  local out
  out=$(run --count 3 "test httpbin")
  assert "search: returns JSON array"     '\['       "$out"
  assert "search: has title field"        '"title"'  "$out"
  assert "search: has url field"          '"url"'    "$out"
  assert "search: has snippet field"      '"snippet"' "$out"
}

# Test 3: gsearch follow <url> — reads a single HTML page.
test_follow() {
  echo "--- 3. follow ---"
  local out
  out=$(run follow "https://httpbin.org/html")
  assert "follow: success field"     '"success":true' "$out"
  assert "follow: url field"         '"url"'          "$out"
  assert "follow: data field"        '"data"'         "$out"
}

# Test 4: gsearch batch search — multi-query search with dedup and meta.
test_batch_search() {
  echo "--- 4. batch search ---"
  local out
  out=$(run batch search --count 3 "httpbin test" "example")
  assert "batch search: results key"     '"results"' "$out"
  assert "batch search: meta key"        '"meta"'    "$out"
  assert "batch search: meta.queries"    '"queries"' "$out"
}

# Test 5: gsearch batch follow — reads multiple URLs in parallel.
test_batch_follow() {
  echo "--- 5. batch follow ---"
  local out
  out=$(run batch follow "https://httpbin.org/html")
  assert "batch follow: results array"     '\['    "$out"
  assert "batch follow: has url field"     '"url"' "$out"
  assert "batch follow: has content field" '"content"' "$out"
}

# Test 6: gsearch batch harvest — full pipeline: search → dedup → follow.
test_batch_harvest() {
  echo "--- 6. batch harvest ---"
  local out
  out=$(run batch harvest --count 2 --max 1 "httpbin test")
  assert "batch harvest: search_results key"  '"search_results"' "$out"
  assert "batch harvest: read_pages key"      '"read_pages"'     "$out"
  assert "batch harvest: meta key"            '"meta"'           "$out"
  assert "batch harvest: meta.queries"        '"queries"'        "$out"
  assert "batch harvest: meta.pages_read"     '"pages_read"'     "$out"
}

# Test 7: error handling — invalid input should produce error message.
test_error_handling() {
  echo "--- 7. error handling ---"
  local out
  out=$(run follow "")
  assert "error: shows usage on empty URL" "Usage" "$out"
}

# Test 8: gsearch screenshot — captures a full-page PNG.
test_screenshot() {
  echo "--- 8. screenshot ---"
  local out file="/tmp/gsearch-test-screenshot.png"
  rm -f "$file"
  out=$(run screenshot "https://httpbin.org/html" --output "$file")
  assert "screenshot: success field" '"success":true' "$out"

  TESTS=$((TESTS+1))
  if [ -f "$file" ] && [ -s "$file" ]; then
    local size
    size=$(wc -c < "$file" | tr -d ' ')
    echo "  ✓ screenshot: file exists ($size bytes)"
    PASS=$((PASS+1))
    rm -f "$file"
  else
    echo "  ✗ screenshot: file not created or empty at $file"
    FAIL=$((FAIL+1))
  fi
}

# Test 9: gsearch pdftotext — verify command is wired up and engine exists.
test_pdftotext() {
  echo "--- 9. pdftotext ---"
  # Running without args should print usage and exit non-zero.
  local out
  out=$(run pdftotext)
  assert "pdftotext: shows usage on no args" "Usage" "$out"

  # Check that the extraction engine exists alongside the CLI.
  TESTS=$((TESTS+1))
  local extractor
  extractor=$(find "$SCRIPT_DIR/.." -name 'pdf-extract.ts' 2>/dev/null | head -1)
  if [ -n "$extractor" ] && [ -f "$extractor" ]; then
    echo "  ✓ pdftotext: engine present ($(basename "$extractor"))"
    PASS=$((PASS+1))
  else
    echo "  ✗ pdftotext: pdf-extract.ts not found"
    FAIL=$((FAIL+1))
  fi
}

# ── Main ───────────────────────────────────────────────────────────

main() {
  echo "gsearch smoke test suite"
  echo "========================"
  echo "CLI:         $CLI"
  echo "Harness:     $(command -v browser-harness-js)"
  echo "Timeout:     ${TIMEOUT_CMD:-none}${TIMEOUT_CMD:+ $TIMEOUT s}"
  echo ""

  test_launch
  test_search
  test_follow
  test_batch_search
  test_batch_follow
  test_batch_harvest
  test_error_handling
  test_screenshot
  test_pdftotext

  echo ""
  echo "Results: $PASS/$TESTS passed, $FAIL failed"
  [ "$FAIL" -eq 0 ] || exit 1
}

main "$@"
