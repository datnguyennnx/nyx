#!/usr/bin/env bash
# gsearch benchmark suite — tests CDP/gsearch as AI agent tooling.
# Each case mimics a real agent task: search, extract, scrape, screenshot.
set -uo pipefail
export GSEARCH_ALLOW_REAL=1

script_dir="$(cd "$(dirname "$0")" && pwd)"
cli="$script_dir/gsearch"

[ -f "$cli" ] || { echo "FAIL: $cli not found" >&2; exit 1; }
command -v browser-harness-js >/dev/null 2>&1 || { echo "skip: browser-harness-js not on PATH" >&2; exit 77; }

run() { "$cli" "$@" 2>&1 || true; }

probe=$(run follow https://news.ycombinator.com --raw 2>/dev/null)
case "$probe" in
  *Cannot*connect*|*ECONNREFUSED*|*connect:*|*WS*error*)
    echo "skip: browser not reachable" >&2; exit 77 ;;
esac

pass=0; fail=0
ok()  { echo "  PASS  $1"; pass=$((pass + 1)); }
bad() { echo "  FAIL  $1"; printf '%s\n' "$2" | sed 's/^[[:space:]]*/        /' | head -10; fail=$((fail + 1)); }
expect_in()   { printf '%s' "$3" | grep -qFe "$2" && ok "$1" || bad "$1" "$3"; }
expect_not()  { printf '%s' "$3" | grep -qFe "$2" && bad "$1" "$3" || ok "$1"; }

extract_json() {
  node -e "try{var d=JSON.parse(require('fs').readFileSync(0,'utf8'));var v=d['$1'];if(v!==undefined&&v!==null)process.stdout.write(typeof v==='object'?JSON.stringify(v):String(v))}catch(e){}" 2>/dev/null
}
expect_json_key() {
  local val; val=$(printf '%s' "$3" | extract_json "$2") && [ -n "$val" ] && ok "$1" || bad "$1" "$3"
}

start_timer() { TIMER_START=$(python3 -c 'import time; print(time.time())' 2>/dev/null); }
elapsed()     { local now=$(python3 -c 'import time; print(time.time())' 2>/dev/null); python3 -c "print(f'{($now-${TIMER_START:=0}):.1f}s')" 2>/dev/null; }

echo "gsearch benchmark"

# ── 1. Full page content extraction ─────────────────────────────────
echo "--- 1. page content ---"
start_timer
text=$(run follow https://news.ycombinator.com)
echo "  time: $(elapsed)"
expect_json_key "JSON schema: .success" "success" "$text"
expect_json_key "JSON schema: .url" "url" "$text"
expect_json_key "JSON schema: .data" "data" "$text"
data=$(printf '%s' "$text" | extract_json "data")
expect_in "HN: loads frontpage stories" "Show HN" "$data"
expect_in "HN: has story points" "points" "$data"
expect_in "HN: has comment links" "comments" "$data"

raw_text=$(run follow https://news.ycombinator.com --raw)
expect_in "HN --raw: contains story titles" "Ask HN" "$raw_text"

# ── 2. CSS selector: single element ────────────────────────────────
echo "--- 2. scrape single ---"
start_timer
title=$(run scrape https://news.ycombinator.com --selector 'title' --raw)
echo "  time: $(elapsed)"
expect_in "scrape title: contains Hacker News" "Hacker News" "$title"

hn_title=$(run scrape https://news.ycombinator.com --selector '.hnname a' --raw)
expect_in "scrape .hnname a: contains Hacker News" "Hacker News" "$hn_title"

# ── 3. CSS selector: list extraction ───────────────────────────────
echo "--- 3. scrape list ---"
start_timer
links=$(run scrape https://news.ycombinator.com --selector 'span.titleline > a' --attr href --list --raw)
echo "  time: $(elapsed)"
expect_in "scrape href list: contains http" "http" "$links"
link_count=$(printf '%s' "$links" | node -e "try{var d=JSON.parse(require('fs').readFileSync(0,'utf8'));console.log(d.length)}catch(e){console.log('0')}" 2>/dev/null)
[ "$link_count" -ge 10 ] && ok "scrape href list: $link_count items" || bad "scrape href list: $link_count items" "$links"

titles=$(run scrape https://news.ycombinator.com --selector 'span.titleline > a' --list --raw)
expect_in "scrape text list: has Show HN" "Show HN" "$titles"

# ── 4. Scrape with attribute extraction ────────────────────────────
echo "--- 4. scrape attr ---"
start_timer
pts=$(run scrape https://news.ycombinator.com --selector '.score' --list --raw)
echo "  time: $(elapsed)"
expect_in "scrape .score list: has points" "points" "$pts"

# ── 5. JSON API follow ─────────────────────────────────────────────
echo "--- 5. json-api ---"
start_timer
json_resp=$(run follow https://jsonplaceholder.typicode.com/todos/1 --json-url)
echo "  time: $(elapsed)"
expect_json_key "json-url: .success" "success" "$json_resp"
json_data=$(printf '%s' "$json_resp" | extract_json "data")
expect_in "json-url: contains userId" '"userId":1' "$json_data"

json_raw=$(run follow https://jsonplaceholder.typicode.com/todos/1 --json-url --raw)
expect_in "json-url --raw: valid JSON" '"userId":1' "$json_raw"

# ── 6. Follow with different content selectors ─────────────────────
echo "--- 6. content selector ---"
start_timer
snippet=$(run follow https://news.ycombinator.com --selector '.hnname' --raw)
echo "  time: $(elapsed)"
expect_in "follow .hnname: contains Hacker News" "Hacker News" "$snippet"

# ── 7. Screenshot ──────────────────────────────────────────────────
echo "--- 7. screenshot ---"
start_timer
ss=$(run screenshot https://news.ycombinator.com --output /tmp/gsearch-test-hn.png)
echo "  time: $(elapsed)"
ss_success=$(printf '%s' "$ss" | extract_json "success")
[ "$ss_success" = "true" ] && [ -f /tmp/gsearch-test-hn.png ] && ok "screenshot: file exists" || bad "screenshot: file" "$ss"
[ -s /tmp/gsearch-test-hn.png ] && ok "screenshot: non-empty" || bad "screenshot: empty" "$(wc -c < /tmp/gsearch-test-hn.png) bytes"
rm -f /tmp/gsearch-test-hn.png

# ── 8. Navigation with wait modes ──────────────────────────────────
echo "--- 8. wait modes ---"
start_timer
load=$(run follow https://en.wikipedia.org/wiki/Web_scraping --wait load --raw 2>/dev/null | head -5)
echo "  time: $(elapsed)"
expect_in "wait=load: returns HTML" "Web scraping" "$load"

start_timer
idle=$(run follow https://en.wikipedia.org/wiki/Web_scraping --wait networkIdle --raw 2>/dev/null | head -5)
echo "  time: $(elapsed)"
expect_in "wait=networkIdle: returns HTML" "Web scraping" "$idle"

almost=$(run follow https://en.wikipedia.org/wiki/Web_scraping --wait almostIdle --raw 2>/dev/null | head -5)
expect_in "wait=almostIdle: returns HTML" "Web scraping" "$almost"

# ── 9. Google search ───────────────────────────────────────────────
echo "--- 9. search ---"
start_timer
search=$(run --count 3 "typescript 5.8 release" 2>/dev/null) || true
echo "  time: $(elapsed)"
search_valid=$(printf '%s' "$search" | node -e "try{var d=JSON.parse(require('fs').readFileSync(0,'utf8'));process.exit(Array.isArray(d)&&d.length>0?0:1)}catch(e){process.exit(1)}" 2>/dev/null) && ok "search: returns non-empty array" || bad "search: returns array" "$search"
has_title=$(printf '%s' "$search" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0].get('title',''))" 2>/dev/null)
expect_in "search: has title" "TypeScript" "$has_title"

# ── 10. Error guards ───────────────────────────────────────────────
echo "--- 10. guards ---"
g1=$("$cli" follow 2>&1); rc1=$?
[ "$rc1" -ne 0 ] && printf '%s' "$g1" | grep -qF "Usage" && ok "guard: follow no url" || bad "guard: follow no url" "rc=$rc1 out=$g1"
g2=$("$cli" follow https://news.ycombinator.com --bogus 2>&1); rc2=$?
[ "$rc2" -ne 0 ] && printf '%s' "$g2" | grep -qF "unknown option" && ok "guard: follow bad flag" || bad "guard: follow bad flag" "rc=$rc2 out=$g2"
g3=$("$cli" --bogus 2>&1); rc3=$?
[ "$rc3" -ne 0 ] && printf '%s' "$g3" | grep -qF "unknown option" && ok "guard: search bad flag" || bad "guard: search bad flag" "rc=$rc3 out=$g3"
g4=$("$cli" "test" extra 2>&1); rc4=$?
[ "$rc4" -ne 0 ] && printf '%s' "$g4" | grep -qF "unexpected argument" && ok "guard: search extra arg" || bad "guard: search extra arg" "rc=$rc4 out=$g4"

# ── Summary ────────────────────────────────────────────────────────
echo
echo "$pass passed, $fail failed"
[ "$fail" -eq 0 ]
