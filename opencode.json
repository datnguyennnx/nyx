{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git reset*": "deny",
      "git diff*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git branch*": "allow"
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "everything": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-everything"],
      "enabled": true
    }
  },
  "mode": {
    "docs": {
      "prompt": "{file:./modes/docs.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "grep": true,
        "glob": true,
        "list": true,
        "bash": true,
        "patch": true
      }
    }
  }
}
